{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "NODE_ENV",
    "SKIP_ENV_CHECK",
    "NEXT_PUBLIC_APP_URL",
    "DATABASE_URL",
    "DATABASE_URI",
    "POSTGRES_URL",
    "DATABASE_PUSH",
    "PAYLOAD_SECRET",
    "BLOB_READ_WRITE_TOKEN",
    "CMS_ISR_REVALIDATE_SECONDS",
    "STRAPI_ISR_REVALIDATE_SECONDS",
    "REVALIDATE_SECRET",
    "STRAPI_REVALIDATE_SECRET",
    "LOG_LEVEL",
    "LOG_FORMAT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "develop": {
      "cache": false,
      "persistent": true
    }
  }
}
