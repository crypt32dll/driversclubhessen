{
  "name": "driversclubhessen",
  "version": "1.0.0",
  "private": true,
  "description": "DriversClub Hessen monorepo",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "better-sqlite3": "12.8.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace web",
    "dev:web": "npm run dev --workspace web",
    "dev:cms": "npm run develop --workspace cms",
    "build": "turbo run build --filter=web",
    "build:web": "turbo run build --filter=web",
    "build:all": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check apps/web/src apps/web/next.config.ts packages/shared/src packages/logger/src",
    "format": "biome format --write apps/web/src apps/web/next.config.ts packages/shared/src packages/logger/src"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.9.6"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linuxmusl-x64": "1.0.4",
    "@img/sharp-linuxmusl-x64": "0.33.5",
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@rollup/rollup-linux-x64-musl": "4.60.1"
  }
}
