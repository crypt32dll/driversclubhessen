# Local development — copy to `.env.local` (gitignored)
# Command: cp .env.local.example .env.local
#
# After connecting Neon on Vercel, pull env into this app (from apps/web):
#   vercel env pull .env.development.local
# Then optionally merge into `.env.local`, or keep both (Next loads .env.development.local in dev).
# Verify Neon + DATABASE_URL: npm run neon:check

# Public site origin (absolute URLs for Payload media — no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postgres for Payload
#
# Recommended: Neon (https://neon.tech) — create a project, then copy the connection string from
# Dashboard → your project → Connection details. Use the "Pooled" / serverless-friendly URI for
# Next.js + Payload. Paste it here as DATABASE_URL for local dev.
#
# Or use the Vercel Neon integration for hosted deploys only; for local dev you still paste the
# same Neon URL (or a dev branch) into this file:
# https://vercel.com/marketplace/neon
#
# Use sslmode=verify-full for Neon to match node-pg semantics and avoid the pg v8 SSL deprecation warning.
# (If Neon’s UI still shows require, the app normalizes Neon hosts at runtime; you can set verify-full here too.)
DATABASE_URL=postgresql://USER:PASSWORD@EP-xxx.region.aws.neon.tech/neondb?sslmode=verify-full

# Payload secret (min 32 chars). Generate: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-openssl-rand-base64-32

# Optional: push schema in dev without migrations
# DATABASE_PUSH=true

# Optional: Vercel Blob for durable uploads (set in Vercel automatically when Blob is enabled)
# BLOB_READ_WRITE_TOKEN=

# ISR + on-demand revalidation
# CMS_ISR_REVALIDATE_SECONDS=3600

# Required for POST /api/revalidate (webhooks). Generate: openssl rand -base64 32
REVALIDATE_SECRET=replace-with-openssl-rand-base64-32

# Logging: pretty in dev; use LOG_FORMAT=json to mimic Vercel locally
# LOG_LEVEL=debug
# LOG_FORMAT=pretty
