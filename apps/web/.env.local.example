# Local development — copy to `.env.local` (gitignored)
# Command: cp .env.local.example .env.local

# Strapi REST base URL (no trailing slash)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Optional: server-side fetch timeout (ms) for Strapi requests
# STRAPI_FETCH_TIMEOUT_MS=10000

# ISR + on-demand revalidation (match production for realistic tests)
# STRAPI_ISR_REVALIDATE_SECONDS=3600

# Required for POST /api/revalidate (Strapi webhooks). Generate: openssl rand -base64 32
# Use the same value in Vercel (REVALIDATE_SECRET) and Strapi webhook Authorization: Bearer …
REVALIDATE_SECRET=replace-with-openssl-rand-base64-32

# Logging: pretty in dev; use LOG_FORMAT=json to mimic Vercel locally
# LOG_LEVEL=debug
# LOG_FORMAT=pretty
