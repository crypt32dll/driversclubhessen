# DriversClub Hessen — Next.js + Payload (reference)
# Copy to `.env.local` for development.

# See also:
# - `.env.local.example` — local development (Neon DATABASE_URL, etc.)
# - `.env.production.example` — Vercel + Neon Marketplace

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=verify-full
PAYLOAD_SECRET=replace-with-openssl-rand-base64-32
