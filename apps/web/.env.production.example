# Vercel — Production / Preview environment variables
# Project → Settings → Environment Variables

# --- Neon Postgres (Vercel Marketplace) ---
# Install: https://vercel.com/marketplace/neon — choose integration mode (new Neon account vs link existing).
# Vercel usually injects DATABASE_URL into your project; this app reads DATABASE_URL (or DATABASE_URI / POSTGRES_URL).
# Ensure Production and Preview scopes get the variable if you use preview DB branches.

# Public site URL (HTTPS, no trailing slash) — used for absolute Payload media URLs
NEXT_PUBLIC_APP_URL=

# Injected by Neon integration when connected, or paste from Neon Dashboard → Connection details.
# Prefer `sslmode=verify-full` on Neon (or rely on runtime normalization in `src/lib/postgres-url.ts`).
DATABASE_URL=

# Payload
PAYLOAD_SECRET=

# Optional: Vercel Blob (recommended on Vercel for durable uploads)
# BLOB_READ_WRITE_TOKEN=

# ISR: TTL for `unstable_cache` (seconds). On-demand updates via POST /api/revalidate + Payload hooks.
# CMS_ISR_REVALIDATE_SECONDS=3600

# On-demand revalidation: same value in webhook Authorization: Bearer …
# openssl rand -base64 32
REVALIDATE_SECRET=

# LOG_LEVEL=info
# LOG_FORMAT=json
