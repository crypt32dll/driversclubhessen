HOST=0.0.0.0
PORT=1337

APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Local dev: sqlite (default). Production (Railway/Render): postgres + DATABASE_URL
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Comma-separated browser origins allowed to call Strapi (Vercel app + local Next)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Optional: Cloudinary for self-hosted Strapi only — set all four (Strapi Cloud uses its own storage)
# CLOUDINARY_UPLOAD=true
# CLOUDINARY_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=
