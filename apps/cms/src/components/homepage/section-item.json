{
  "collectionName": "components_homepage_section_items",
  "info": {
    "displayName": "Section Item",
    "description": "Flexible homepage content section item"
  },
  "attributes": {
    "variant": {
      "type": "enumeration",
      "enum": ["highlight", "rule", "about", "location", "social"],
      "default": "highlight"
    },
    "icon": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
